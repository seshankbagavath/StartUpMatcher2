PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://postgres@localhost:5432/liftoff
# OpenAI-compatible AI provider. Defaults target Groq.
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.groq.com/openai/v1
AI_INTEGRATIONS_OPENAI_API_KEY=your-groq-api-key-here
# Chat model id (Groq). Examples: llama-3.3-70b-versatile, openai/gpt-oss-120b
AI_MODEL=llama-3.3-70b-versatile
